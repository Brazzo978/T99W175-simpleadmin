#!/bin/sh
set -eu

TTL_FILE="${TTL_FILE:-/persist/ttlvalue}"
IPTABLES="${IPTABLES:-/usr/sbin/iptables}"
IP6TABLES="${IP6TABLES:-/usr/sbin/ip6tables}"

ensure_ttl_file() {
    mkdir -p "$(dirname "$TTL_FILE")"
    if [ ! -f "$TTL_FILE" ]; then
        printf '0\n' > "$TTL_FILE"
    fi
    chmod 0644 "$TTL_FILE" 2>/dev/null || true
}

read_ttl() {
    ensure_ttl_file
    ttl="$(sed -n 's/[^0-9]//gp' "$TTL_FILE" | head -n1)"
    case "$ttl" in
        ''|*[!0-9]*) ttl=0 ;;
    esac
    if [ "$ttl" -gt 255 ] 2>/dev/null; then
        ttl=0
    fi
    printf '%s\n' "$ttl"
}

delete_ipv4_rules() {
    command -v "$IPTABLES" >/dev/null 2>&1 || return 0
    while "$IPTABLES" -w 5 -t mangle -S POSTROUTING 2>/dev/null | grep -q -- '-j TTL --ttl-set'; do
        rule="$("$IPTABLES" -w 5 -t mangle -S POSTROUTING 2>/dev/null | sed -n '/-j TTL --ttl-set/{s/^-A POSTROUTING //;p;q;}')"
        [ -n "$rule" ] || break
        # shellcheck disable=SC2086
        "$IPTABLES" -w 5 -t mangle -D POSTROUTING $rule 2>/dev/null || break
    done
}

delete_ipv6_rules() {
    command -v "$IP6TABLES" >/dev/null 2>&1 || return 0
    while "$IP6TABLES" -w 5 -t mangle -S POSTROUTING 2>/dev/null | grep -q -- '-j HL --hl-set'; do
        rule="$("$IP6TABLES" -w 5 -t mangle -S POSTROUTING 2>/dev/null | sed -n '/-j HL --hl-set/{s/^-A POSTROUTING //;p;q;}')"
        [ -n "$rule" ] || break
        # shellcheck disable=SC2086
        "$IP6TABLES" -w 5 -t mangle -D POSTROUTING $rule 2>/dev/null || break
    done
}

start_rules() {
    ttl="$(read_ttl)"
    delete_ipv4_rules
    delete_ipv6_rules

    if [ "$ttl" -gt 0 ]; then
        "$IPTABLES" -w 5 -t mangle -I POSTROUTING -o rmnet+ -j TTL --ttl-set "$ttl"
        if command -v "$IP6TABLES" >/dev/null 2>&1; then
            "$IP6TABLES" -w 5 -t mangle -I POSTROUTING -o rmnet+ -j HL --hl-set "$ttl" 2>/dev/null || true
        fi
        echo "TTL override enabled: $ttl"
    else
        echo "TTL override disabled"
    fi
}

stop_rules() {
    delete_ipv4_rules
    delete_ipv6_rules
    echo "TTL override rules removed"
}

case "${1:-}" in
    start)
        start_rules
        ;;
    stop)
        stop_rules
        ;;
    restart)
        stop_rules
        start_rules
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac
