#!/bin/bash
set -eu

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/session_utils.sh"

TTL_FILE="${TTL_FILE:-/persist/ttlvalue}"

if ! session_load; then
    send_json_response 401 '{"status":"error","message":"Authentication required"}'
    exit 0
fi

ttlvalue="0"
if [ -f "$TTL_FILE" ]; then
    ttlvalue="$(tr -cd '0-9' < "$TTL_FILE" | cut -c1-3)"
fi

if ! [[ "${ttlvalue:-}" =~ ^[0-9]{1,3}$ ]]; then
    ttlvalue="0"
fi

ttl_int=$((10#$ttlvalue))
if [ "$ttl_int" -gt 255 ]; then
    ttl_int=0
fi

effective_ttl=""
if command -v iptables >/dev/null 2>&1; then
    effective_ttl="$(iptables -w 5 -t mangle -S POSTROUTING 2>/dev/null | sed -n 's/.* -j TTL --ttl-set \([0-9][0-9]*\).*/\1/p' | head -n1 || true)"
fi

ttlenabled=false
if [ -n "$effective_ttl" ]; then
    ttl_int="$effective_ttl"
    ttlenabled=true
elif [ "$ttl_int" -gt 0 ]; then
    ttlenabled=false
fi

payload=$(cat <<EOF
{
  "status":"ok",
  "isEnabled":$ttlenabled,
  "ttl":$ttl_int
}
EOF
)

send_json_response 200 "$payload"
