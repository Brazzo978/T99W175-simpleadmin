#!/bin/bash
set -eu

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/session_utils.sh"

TTL_FILE="${TTL_FILE:-/persist/ttlvalue}"
TTL_HELPER="${TTL_HELPER:-/opt/scripts/ttl/ttl-override}"

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    printf '%s' "$str"
}

url_decode() {
    local data="${1//+/ }"
    printf '%b' "${data//%/\\x}"
}

parse_ttlvalue() {
    local qs="${QUERY_STRING:-}"
    local pair key val
    ttlvalue=""

    IFS='&' read -ra pairs <<< "$qs"
    for pair in "${pairs[@]}"; do
        [ -n "$pair" ] || continue
        key="${pair%%=*}"
        val="${pair#*=}"
        case "$key" in
            ttlvalue)
                ttlvalue="$(url_decode "$val")"
                ;;
        esac
    done
}

if ! session_load; then
    send_json_response 401 '{"status":"error","message":"Authentication required"}'
    exit 0
fi

if ! session_require_role "admin"; then
    send_json_response 403 '{"status":"error","message":"Admin privileges required"}'
    exit 0
fi

parse_ttlvalue

if ! [[ "$ttlvalue" =~ ^[0-9]{1,3}$ ]]; then
    send_json_response 400 '{"status":"error","message":"TTL value must be an integer from 0 to 255"}'
    exit 0
fi

ttl_int=$((10#$ttlvalue))
if [ "$ttl_int" -lt 0 ] || [ "$ttl_int" -gt 255 ]; then
    send_json_response 400 '{"status":"error","message":"TTL value must be an integer from 0 to 255"}'
    exit 0
fi

mkdir -p "$(dirname "$TTL_FILE")"
printf '%s\n' "$ttl_int" > "$TTL_FILE"
chmod 0644 "$TTL_FILE"

helper_output=""
if [ -x "$TTL_HELPER" ]; then
    if ! helper_output="$("$TTL_HELPER" restart 2>&1)"; then
        escaped="$(json_escape "$helper_output")"
        send_json_response 500 "{\"status\":\"error\",\"message\":\"Unable to apply TTL rules\",\"detail\":\"$escaped\"}"
        exit 0
    fi
else
    send_json_response 500 '{"status":"error","message":"TTL helper is not installed"}'
    exit 0
fi

enabled=false
if [ "$ttl_int" -gt 0 ]; then
    enabled=true
fi

escaped="$(json_escape "$helper_output")"
payload=$(cat <<EOF
{
  "status":"ok",
  "isEnabled":$enabled,
  "ttl":$ttl_int,
  "detail":"$escaped"
}
EOF
)

send_json_response 200 "$payload"
